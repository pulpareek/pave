# PAVE — Platform Asset Vending Engine
# Copy to `.env` (gitignored) and fill in for local development, or set these as
# app/bundle config when deploying. NOTHING here is a secret by default; Lakebase
# auth uses short-lived OAuth tokens minted at runtime.

# ---- Databricks connection (local dev) ----
# Uses your Databricks CLI profile by default; override the profile name if needed.
DATABRICKS_CONFIG_PROFILE=DEFAULT

# ---- Provisioning target plane (what PAVE vends into) ----
# UC catalog approved schemas are provisioned into (e.g. main).
PARENT_CATALOG=

# ---- App state + audit ----
# UC catalog/schema for PAVE's audit + asset-registry Delta mirror.
AUDIT_CATALOG=
AUDIT_SCHEMA=pave
# Schema PAVE owns for operational state in Lakebase.
PAVE_SCHEMA=pave
# Lakebase (managed Postgres) instance name for operational state.
LAKEBASE_INSTANCE=

# ---- FinOps / system tables ----
# SQL warehouse ID for system.billing.usage queries + audit Delta writes.
DATABRICKS_WAREHOUSE_ID=

# ---- Engine ----
# inprocess = run the engine in the backend (demo default); job = SoD-hardened Job path.
PROVISION_MODE=inprocess
# Per-resource real|simulated overrides as JSON, e.g. {"cluster":"real"}. Empty = defaults.
PROVIDER_MODES=

# ---- Compute governance (cluster policy) ----
# Company cluster policy auto-attached to vended clusters. Empty ID = create-if-missing.
COMPANY_CLUSTER_POLICY_NAME=PAVE Standard
COMPANY_CLUSTER_POLICY_ID=

# ---- Intake co-pilot ----
# Foundation Model serving endpoint the NL intake co-pilot calls (heuristic fallback if absent).
LLM_ENDPOINT=databricks-claude-sonnet-4

# ---- AI gateway provisioning (external models) ----
# Secret scope/key holding an external-model provider API key. Empty = Databricks-hosted only.
AI_GATEWAY_SECRET_SCOPE=
AI_GATEWAY_SECRET_KEY=

# ---- Multi-workspace routing (optional) ----
# Comma-separated target workspace hosts the intake picker offers (in addition to "this
# workspace"). For REAL provisioning into a target, that workspace must be reachable by the
# app's identity (or per-target SP creds) — see providers/_sdk.client() and
# docs/ADMIN_CAPABILITIES.md. Leave empty to provision only into the app's own workspace.
PAVE_TARGET_WORKSPACES=
# Account-level (uncomment the scaffolds in providers/workspace.py to use):
# METASTORE_ID=          # attach this UC metastore to a newly vended workspace

# ---- Pre-approved external locations (catalog/schema external storage) ----
# Comma-separated names of admin-registered UC external locations the intake form offers
# for external catalogs/schemas. Requesters PICK from this list — they never type a raw
# s3:///abfss:// path. Empty = only managed storage is offered.
PAVE_EXTERNAL_LOCATIONS=

# ---- SAFETY KILL-SWITCH ----
# Real providers only run when this is 1/true. Default OFF so local runs never mutate
# the workspace (everything degrades to simulated). The deployed app sets this to 1.
PAVE_ALLOW_REAL=0

# ---- Local demo identity (when not behind the Databricks Apps proxy) ----
# DEV_ROLE=admin           # force a role locally: requester | approver | admin
# DEV_APPROVERS=you@co.com # comma-separated approver emails for local testing

# ---- Approval notifications (email + deep-link) ----
# Approvers get an email with a clickable link to the approval page when a request lands.
# APPROVERS defines both who can approve AND who is emailed.
APPROVERS=
# Base URL of the deployed app, used to build an absolute deep-link in the email
# (e.g. https://pave-<id>.aws.databricksapps.com). Empty = a relative #approvals/{id}.
APP_URL=
# SMTP relay — Databricks Apps have NO built-in email, so mail only SENDS when SMTP_HOST
# is set; otherwise PAVE simulates (logs + audits) the notification. All optional.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=pave-noreply@databricks.com
SMTP_USE_TLS=1
